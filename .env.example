# Directory containing credentials.json and token.json (default: current working directory)
# CREDENTIALS_DIR=.

# Path to Google OAuth credentials file (default: credentials.json)
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Path to Gmail token file (default: token.json)
# GMAIL_TOKEN_FILE=token.json

# Access mode: readonly, standard (default), or dangerous
# IOBOX_MODE=standard

# Account profile name for multi-account token storage (default: default)
# IOBOX_ACCOUNT=default
